# ---- Database (Neon Postgres + pgvector) ----
# Pooled connection string used by the app at runtime (PgBouncer).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
# Direct (non-pooled) connection — required by Prisma Migrate for DDL.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Auth ----
JWT_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"

# ---- OpenAI ----
OPENAI_API_KEY="sk-..."

# ---- App ----
# Origin of the Next.js frontend, used for CORS allow-list.
FRONTEND_URL="http://localhost:3000"
PORT=4000
